# Server
PORT=3001
NODE_ENV=development

# Database - PostgreSQL (Neon/Supabase/etc)
DATABASE_URL=postgresql://user:password@host:5432/claimsub?sslmode=require

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Stedi API (for future clearinghouse integration)
STEDI_API_KEY=
STEDI_BASE_URL=https://healthcare.us.stedi.com/2024-04-01
