# Reddably backend — environment variables.
# Copy to `.env` for local dev. NEVER commit real values; in AWS these come from
# Lambda environment config / Secrets Manager.

# PostgreSQL (RDS) connection string. Format:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://reddably_app:CHANGE_ME@localhost:5432/reddably

# Set to "disable" ONLY for local plaintext Postgres. Leave unset against RDS (TLS).
# DB_SSL=disable

# Max pooled connections per warm Lambda container (keep small).
# DB_POOL_MAX=2

# JWT signing secret (HS256). Use a long, random value (e.g. `openssl rand -hex 32`).
JWT_SECRET=CHANGE_ME_use_a_long_random_secret

# JWT lifetime. Accepts zeit/ms strings (e.g. 12h, 7d). Default: 12h.
# JWT_EXPIRES_IN=12h

# Stedi Healthcare API key — used by the VOB eligibility check (handlers/vob.js)
# and the Stedi claims adapter. In AWS this is hydrated out-of-band from SSM.
STEDI_API_KEY=CHANGE_ME

# --- 837P usageIndicator: test (T) vs production (P) claims -------------------
# Every claim carries an explicit usageIndicator. The default is ALWAYS 'P'; the
# two variables below are the ONLY ways to produce a 'T'. Both are operator-set
# Lambda config — nothing a practice user can send reaches them.
#
# Leave BOTH unset in production. A claim filed as 'T' is never adjudicated and
# never rejected: the practice simply never gets paid, with nothing to alert them.
#
#   STEDI_ALLOW_TEST_SUBMISSIONS=true
#     Permits a single request to opt in, via `test_submission: true` on
#     POST /claims/:id/submit (practice admins only). Used for the STEDITEST
#     validation runs. A test submission requested without this set is REFUSED
#     (403), never quietly downgraded to a production claim.
#
#   STEDI_FORCE_TEST_SUBMISSIONS=true
#     Marks the whole deployment as non-production (staging, local). EVERY claim
#     it files goes out as 'T' regardless of the request, so a staging box
#     structurally cannot emit a production claim.
#
# The documented Stedi test-claim path is a PRODUCTION api key + usageIndicator
# 'T' + the STEDITEST payer, which Stedi does not forward to a real payer. Test
# api keys cannot submit claims at all.
# STEDI_ALLOW_TEST_SUBMISSIONS=
# STEDI_FORCE_TEST_SUBMISSIONS=

# App-layer field-encryption key (AES-256-GCM) for the provider billing TIN
# (backend/lib/crypto.js). MUST be 32 bytes, as base64 (`openssl rand -base64 32`)
# or hex (`openssl rand -hex 32`). Read by the providers + claims handlers. In AWS
# this is hydrated out-of-band from SSM. Without it, saving a person billing TIN
# fails closed (never stored in the clear).
FIELD_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32

# NPPES NPI Registry (public CMS registry; no key). Overridable base URL/timeout.
# NPPES_BASE_URL=https://npiregistry.cms.hhs.gov/api/
# NPPES_TIMEOUT_MS=8000

# --- Vercel Stripe functions (env set in the Vercel project, NOT on the Lambdas) --
# The Stripe-facing endpoints run as Vercel functions because the VPC Lambdas have
# no NAT egress to Stripe. These are read there (or from a local .env when running
# the /api functions locally) — the Lambdas never use them.
#   STRIPE_SECRET_KEY         — setup-intent / charge-fee / vob-activate (Checkout).
#   STRIPE_VOB_WEBHOOK_SECRET — signature secret for /subscription/vob/webhook
#                               (api/vob-webhook.js) that flips a practice's plan.
#   APP_BASE_URL              — base for Checkout success/cancel URLs used by
#                               vob-activate. Default: https://claims.sessionably.com
# STRIPE_SECRET_KEY=CHANGE_ME
# STRIPE_VOB_WEBHOOK_SECRET=CHANGE_ME
# APP_BASE_URL=https://claims.sessionably.com
